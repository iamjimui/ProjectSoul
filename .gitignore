# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
projet_libre/[Ll]ibrary/
projet_libre/[Tt]emp/
projet_libre/[Oo]bj/
projet_libre/[Bb]uild/
projet_libre/[Bb]uilds/
projet_libre/[Ll]ogs/
projet_libre/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
projet_libre/[Mm]emoryCaptures/

# Recordings can get excessive in size
projet_libre/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
projet_libre//[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
projet_libre/.vs/

# Gradle cache directory
projet_libre/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
projet_libre/ExportedObj/
projet_libre/.consulo/
projet_libre/*.csproj
projet_libre/*.unityproj
projet_libre/*.sln
projet_libre/*.suo
projet_libre/*.tmp
projet_libre/*.user
projet_libre/*.userprefs
projet_libre/*.pidb
projet_libre/*.booproj
projet_libre/*.svd
projet_libre/*.pdb
projet_libre/*.mdb
projet_libre/*.opendb
projet_libre/*.VC.db

# Unity3D generated meta files
projet_libre/*.pidb.meta
projet_libre/*.pdb.meta
projet_libre/*.mdb.meta

# Unity3D generated file on crash reports
projet_libre/sysinfo.txt

# Builds
projet_libre/*.apk
projet_libre/*.aab
projet_libre/*.unitypackage
projet_libre/*.app

# Crashlytics generated file
projet_libre/crashlytics-build.properties

# Packed Addressables
projet_libre/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
projet_libre/[Aa]ssets/[Ss]treamingAssets/aa.meta
projet_libre/[Aa]ssets/[Ss]treamingAssets/aa/*